{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeployKeys Desktop",
  "version": "0.1.0",
  "identifier": "co.deploykeys.desktop",
  "build": {
    "frontendDist": "../deploykeys-ui/dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": {
      "cwd": "../deploykeys-ui",
      "script": "trunk serve --port 8000"
    },
    "beforeBuildCommand": {
      "cwd": "../deploykeys-ui",
      "script": "trunk build --release"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DeployKeys Desktop",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 29.5
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/images/png/desktop/32x32.png",
      "assets/images/png/desktop/128x128.png",
      "assets/images/png/desktop/128x128@2x.png",
      "assets/images/icns/icon.icns",
      "assets/images/ico/icon.ico"
    ]
  }
}
